{
  "manifest_version": 3,
  "name": "goal.live Clickable Players Lab",
  "version": "0.1.0",
  "description": "Experimental clickable-player overlay lab for goal.live",
  "permissions": ["activeTab"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://tvgo.t-mobile.cz/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/watch*",
        "https://tvgo.t-mobile.cz/*"
      ],
      "js": ["content-script.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "goal.live Clickable Players Lab",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon16.svg",
      "128": "icons/icon16.svg"
    }
  },
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon16.svg",
    "128": "icons/icon16.svg"
  }
}
