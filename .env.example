# Copy to .env and fill in your values

# Feature flags
VITE_USE_MOCK=true
VITE_USE_REAL_WALLET=false
VITE_DEBUG=false
VITE_APP_NAME=goal.live

# Platform escrow wallet address (Sepolia)
VITE_PLATFORM_WALLET=0x0000000000000000000000000000000000000000

# Supabase — get from supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Server-side only — NEVER use in frontend bundle
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# World ID — get app_id from developer.worldcoin.org
# Frontend — used by IDKitWidget
VITE_WORLD_APP_ID=app_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase Edge Function secret — set via: supabase secrets set WORLD_APP_ID=app_xxx
# Never put the real app_id in this file
WORLD_APP_ID=app_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
